<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        android:background="@color/background_card">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/advanced_settings_title"
            app:titleTextColor="@color/white"
            app:navigationIcon="?attr/homeAsUpIndicator" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- Группа: Сеть -->
            <TextView
                android:text="Локальная сеть"
                android:textColor="@color/opera_red"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilBindAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/pref_bind_address"
                android:textColorHint="@color/text_secondary"
                app:hintTextColor="@color/opera_red"
                app:boxStrokeColor="@color/opera_red"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_help"
                app:endIconTint="@color/text_secondary"
                app:expandedHintEnabled="false"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBindAddress"
                    android:inputType="text"
                    android:hint="@string/pref_bind_address_hint"
                    android:imeOptions="actionNext"
                    android:textColor="@color/text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swProxyOnly"
                android:text="@string/pref_proxy_only"
                android:textColor="@color/text_primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:paddingEnd="4dp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swSocksMode"
                android:text="@string/pref_socks_mode"
                android:textColor="@color/text_primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:paddingEnd="4dp" />

            <!-- Группа: Трафик -->
            <TextView
                android:text="Трафик и маскировка"
                android:textColor="@color/opera_red"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilFakeSni"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/pref_fake_sni"
                android:textColorHint="@color/text_secondary"
                app:hintTextColor="@color/opera_red"
                app:boxStrokeColor="@color/opera_red"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_help"
                app:endIconTint="@color/text_secondary"
                app:expandedHintEnabled="false"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFakeSni"
                    android:inputType="textUri"
                    android:hint="@string/pref_fake_sni_hint"
                    android:imeOptions="actionNext"
                    android:textColor="@color/text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilUpstreamProxy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/pref_upstream_proxy"
                android:textColorHint="@color/text_secondary"
                app:hintTextColor="@color/opera_red"
                app:boxStrokeColor="@color/opera_red"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_help"
                app:endIconTint="@color/text_secondary"
                app:expandedHintEnabled="false"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUpstreamProxy"
                    android:inputType="textUri"
                    android:hint="@string/pref_upstream_proxy_hint"
                    android:imeOptions="actionNext"
                    android:textColor="@color/text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Группа: DNS -->
            <TextView
                android:text="DNS"
                android:textColor="@color/opera_red"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilBootstrapDns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/pref_bootstrap_dns"
                android:textColorHint="@color/text_secondary"
                app:hintTextColor="@color/opera_red"
                app:boxStrokeColor="@color/opera_red"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_help"
                app:endIconTint="@color/text_secondary"
                app:expandedHintEnabled="false"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBootstrapDns"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:hint="@string/pref_bootstrap_dns_hint"
                    android:textColor="@color/text_primary"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:clickable="true"
                    android:cursorVisible="false" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTestUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/pref_test_url"
                android:textColorHint="@color/text_secondary"
                app:hintTextColor="@color/opera_red"
                app:boxStrokeColor="@color/opera_red"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_help"
                app:endIconTint="@color/text_secondary"
                app:expandedHintEnabled="false"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTestUrl"
                    android:inputType="textUri"
                    android:hint="@string/pref_test_url_hint"
                    android:textColor="@color/text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Spinner для DNS Strategy -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/item_background"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:text="@string/pref_tun_dns_strategy"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:text="Метод обработки DNS в туннеле"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <Spinner
                    android:id="@+id/spDnsStrategy"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:minWidth="130dp"
                    android:spinnerMode="dropdown" />

                <ImageView
                    android:id="@+id/ivHelpDnsStrategy"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_help"
                    app:tint="@color/text_secondary"
                    android:layout_marginStart="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>

           <!-- API ADDRESS -->
            <TextView
                android:text="В случае ошибок при подключении к серверам"
                android:textColor="@color/opera_red"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" />
            <com.google.android.material.textfield.TextInputLayout

                android:id="@+id/tilApiAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/pref_api_address"
                android:textColorHint="@color/text_secondary"
                app:hintTextColor="@color/opera_red"
                app:boxStrokeColor="@color/opera_red"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_sort_by_size"
                app:endIconTint="@color/opera_red"
                app:expandedHintEnabled="false"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApiAddress"
                    android:inputType="textUri"
                    android:hint="@string/pref_api_address_hint"
                    android:imeOptions="actionNext"
                    android:textColor="@color/text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Группа: Логи -->
            <TextView
                android:text="Отладка"
                android:textColor="@color/opera_red"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/item_background"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:text="@string/pref_verbosity"
                    android:textColor="@color/text_primary"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content" />

                <Spinner
                    android:id="@+id/spVerbosity"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:minWidth="120dp" />
            </LinearLayout>

            <!-- КОМАНДНАЯ СТРОКА -->
            <TextView
                android:text="@string/pref_cmd_args"
                android:textColor="@color/opera_red"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swManualMode"
                android:text="@string/pref_manual_mode"
                android:textColor="@color/text_primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:paddingEnd="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilCmdPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="CMD Preview / Override"
                android:textColorHint="@color/text_secondary"
                app:hintTextColor="@color/opera_red"
                app:boxStrokeColor="@color/opera_red"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCmdPreview"
                    android:inputType="textMultiLine"
                    android:textColor="@color/text_primary"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:minLines="3"
                    android:gravity="top"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Кнопки -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:text="@string/btn_save"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                app:backgroundTint="@color/opera_red" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReset"
                android:text="@string/btn_reset_defaults"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/text_secondary"
                android:layout_width="match_parent"
                android:layout_height="44dp" />

            <!-- Ссылка на GitHub -->
            <TextView
                android:text="@string/about_section"
                android:textColor="@color/opera_red"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/btnGithubLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/item_background"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:layout_marginBottom="22dp">

                <ImageView
                    android:src="@drawable/ic_github"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="16dp"
                    app:tint="@color/text_primary" />

                <TextView
                    android:text="@string/github_link_text"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>