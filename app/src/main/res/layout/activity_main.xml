<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent" android:background="@color/background_app">

    <com.google.android.material.appbar.AppBarLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        android:background="@color/background_card">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="33dp"
            android:visibility="visible"
            app:title="@string/app_name"
            app:titleTextColor="@color/white"
            tools:ignore="TextSizeCheck" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="5dp">

            <!-- Карточка региона -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:cardBackgroundColor="@color/background_card"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <!-- Регион: горизонтальное расположение -->

                    <TextView
                        android:id="@+id/Region"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/region_title"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="visible" />

                    <RadioGroup
                        android:id="@+id/rgCountry"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbEU"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:checked="true"
                            android:minHeight="42dp"
                            android:padding="0dp"
                            android:text="@string/ServerEU"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            app:buttonTint="@color/opera_red" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbAS"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:minHeight="42dp"
                            android:padding="0dp"
                            android:text="@string/ServerAS"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            app:buttonTint="@color/opera_red" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbAM"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:minHeight="42dp"
                            android:padding="0dp"
                            android:text="@string/ServerAM"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            app:buttonTint="@color/opera_red" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Карточка настроек -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                app:cardBackgroundColor="@color/background_card"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/Settings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/settings_title"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="visible"
                        tools:visibility="visible" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:hint="@string/dns_hint"
                        android:textColorHint="@color/text_secondary"
                        app:boxStrokeColor="@color/opera_red"
                        app:hintTextColor="@color/opera_red">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDns"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:hint="@string/dns_hint"
                            android:inputType="text"
                            android:text="@string/DNS_for_VPN"
                            android:textAlignment="textStart"
                            android:textAppearance="@style/TextAppearance.AppCompat.Small"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="normal"
                            android:visibility="visible"
                            tools:visibility="visible" />
                    </com.google.android.material.textfield.TextInputLayout>


                    <!-- Выбор режима проксирования -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="2dp"
                        android:text="@string/mode_title"
                        android:textColor="@color/opera_red"
                        android:textSize="14sp"
                        tools:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rgAppMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbModeWhitelist"
                            android:layout_width="match_parent"
                            android:layout_height="33dp"
                            android:checked="true"
                            android:minHeight="29dp"
                            android:text="@string/mode_whitelist"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            app:buttonTint="@color/opera_red" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbModeWhitelistDisallowed"
                            android:layout_width="match_parent"
                            android:layout_height="33dp"
                            android:minHeight="29dp"
                            android:text="@string/mode_whitelist_disallowed"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            app:buttonTint="@color/opera_red" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbModeBlacklist"
                            android:layout_width="match_parent"
                            android:layout_height="33dp"
                            android:minHeight="29dp"
                            android:text="@string/mode_blacklist"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            app:buttonTint="@color/opera_red" />
                    </RadioGroup>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectApps"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="5dp"
                        android:minHeight="30dp"
                        android:text="@string/app_selector_btn"
                        android:textColor="#F44336"
                        app:strokeColor="@color/opera_red"
                        tools:minHeight="30dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAdvanced"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="0dp"
                        android:minHeight="30dp"
                        android:text="@string/btn_settings_advanced"
                        android:textColor="@color/text_primary"
                        app:strokeColor="@color/text_secondary"
                        tools:minHeight="30dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/app_selector_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        app:autoSizeMinTextSize="10sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Кнопка запуска -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:elevation="6dp"
                android:padding="11dp"
                android:text="@string/btn_start"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/opera_red"
                app:cornerRadius="40dp" />

            <!-- Лог -->
            <LinearLayout
                android:id="@+id/llLogContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Заголовок -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/Logs_description"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Кнопка свернуть/развернуть -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCollapseLog"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="48dp"
                        android:layout_height="40dp"
                        android:padding="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:minWidth="0dp"
                        app:icon="@android:drawable/arrow_up_float"
                        app:iconTint="@color/text_secondary"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearLog"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:text="@string/ClearLogs"
                        android:textColor="@color/text_secondary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyLog"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:text="@string/CopyLogs"
                        android:textColor="@color/opera_red" />
                </LinearLayout>

                <!-- Контент логов, который будем скрывать -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvLogContent"
                    android:layout_width="match_parent"
                    android:layout_height="400dp"
                    app:cardBackgroundColor="@color/log_background"
                    app:cardCornerRadius="8dp"
                    app:contentPadding="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                    <ScrollView
                        android:id="@+id/svLog"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fillViewport="true"
                        android:minHeight="100dp">

                        <TextView
                            android:id="@+id/tvLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:minHeight="80dp"
                            android:padding="8dp"
                            android:textColor="@color/log_text"
                            android:textIsSelectable="true"
                            android:textSize="10sp" />
                    </ScrollView>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>