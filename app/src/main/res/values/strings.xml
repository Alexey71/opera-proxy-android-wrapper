    <!-- Расширенные настройки (Labels & Hints) -->
    <string name="pref_bind_address">Прослушиваемый IP:Порт</string>
    <string name="pref_bind_address_hint">127.0.0.1:1085</string>
    <string name="help_bind_address">Адрес и порт локального интерфейса для прослушивания входящих соединений.\nПорт может быть установлен в диапазоне от 1024 до 65535</string>

    <string name="pref_bootstrap_dns">DNS для инициализации соединения</string>
    <string name="pref_bootstrap_dns_hint">Например https://8.8.8.8/dns-query</string>
    <string name="help_bootstrap_dns">Список DoH/DoT резолверов через запятую для инициализации соединения.\nОн нужен для выбора защищённых DNS-серверов, которые шифруют запросы на разрешение доменов, защищая от перехвата, подмены и слежки провайдерами, маскируя трафик под обычный HTTPS.\nСтроку можно полностью удалить и использовать параметр --api-address для прямого обращения к серверам Opera.</string>

    <string name="pref_fake_sni">Подмена названия сайта (Fake SNI)</string>
    <string name="pref_fake_sni_hint">Любой открывающийся сайт</string>
    <string name="help_fake_sni">Fake SNI маскирует настоящее название сайта в TLS-соединении, чтобы обойти блокировки провайдера или цензуру.\n\nАдрес ЛЮБОГО сайта из "белого списка" провайдера, который работает в мобильной сети/WiFI.\n\nБез www или http:// или https://</string>

    <string name="pref_upstream_proxy">Промежуточный прокси-сервер (Upstream Proxy)</string>
    <string name="pref_upstream_proxy_hint">Например socks5://127.0.0.1:1080</string>
    <string name="help_upstream_proxy">Внешний прокси, через который будет проходить весь трафик.\nМожно совместить с ByeByeDPI в режиме прокси.\n\nПоддерживает формат:\nhttp|https|socks5|socks5h://[login:password@]host[:port]\n\nПримеры:\nhttp://user:password@192.168.1.1:3128\nsocks5://127.0.0.1:1080.</string>

    <!-- API/IP ADDRESS -->
    <string name="pref_api_address">API или IP для подключения к серверу</string>
    <string name="pref_api_address_hint">api.sec-tunnel.com или вручную</string>
    <string name="help_api_address">Адрес API сервера Opera. Установка этого параметра позволяет подключиться напрямую к указанному серверу.\n\nНажмите на иконку списка справа, чтобы выбрать стандартные сервера.\n\nЛибо в режиме командной строки запустите -country EU -list-proxies что бы узнать IP адресс для прямого подключения.</string>
    <string name="dialog_clear_bootstrap_title">Очистить DNS Bootstrap?</string>
    <string name="dialog_clear_bootstrap_msg">Вы установили прямой API/IP адрес.\n\Хотите очистить поле "DNS для инициализации", чтобы соединение шло напрямую без резолвинга через DoH.</string>

    <string name="pref_verbosity">Логи</string>
    <string name="help_verbosity">Детализация логов. 10 - макс. детализация, 50 - только критические ошибки.</string>

    <string name="pref_socks_mode">Режим SOCKS5</string>
    <string name="help_socks_mode">Если включено, локальный порт ожидает SOCKS5 соединения вместо HTTP прокси.</string>

    <string name="pref_proxy_only">Режим «Только Прокси»</string>
    <string name="help_proxy_only">Запускает только локальный сервер без создания VPN-туннеля.\nТребует ручной настройки прокси в других приложениях или Wi-Fi соединении Android с указанием "Прослушиваемого IP:Порта".</string>
    
    <string name="pref_test_url">Тестовый URL для выбора быстрого сервера (Benchmark)</string>
    <string name="pref_test_url_hint">Например https://ajax.googleapis.com/ajax/libs/indefinite-observable/2.0.1/indefinite-observable.bundle.js</string>
    <string name="help_test_url">URL, используемый для тестирования скорости и выбора самого быстрого сервера. Ожидает ответа со статусом 200.</string>
    
    <string name="pref_cmd_args">Аргументы запуска</string>
    <string name="pref_manual_mode">Ручное редактирование команды</string>
    <string name="help_manual_mode">Если включено, сервис использует строку ниже как аргументы запуска (игнорируя другие настройки выше).\nПути к бинарнику и сертификату добавляются автоматически.</string>
    
    <string name="pref_tun_dns_strategy">Tun2Proxy DNS</string>
    <string name="help_tun_dns_strategy">Метод обработки DNS-запросов внутри VPN-туннеля:\nVirtual: Fake-IP (быстро, но может ломать некоторые приложения)\nOver TCP: Отправка DNS через TCP прокси (стабильно)</string>

    <string-array name="dns_strategy_labels">
